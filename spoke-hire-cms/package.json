{
  "name": "spoke-hire-cms",
  "version": "1.0.0",
  "description": "SpokeHire CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" SKIP_PRISMA_GENERATE=true next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation SKIP_PRISMA_GENERATE=true next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/index.ts",
    "seed:images": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-images.ts",
    "seed:header": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-header.ts",
    "seed:footer": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-footer.ts",
    "export:staging": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/export-staging.ts",
    "import:production": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/import-production.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.68.4",
    "@payloadcms/next": "3.68.4",
    "@payloadcms/richtext-lexical": "3.68.4",
    "@payloadcms/storage-s3": "3.68.4",
    "@payloadcms/ui": "3.68.4",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "15.4.10",
    "payload": "3.68.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "jsdom": "26.1.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
