{
  "name": "spoke-hire-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "analyze-data": "tsx scripts/analyze-data.ts",
    "migrate-data": "tsx scripts/migrate-data.ts",
    "remigrate-data": "tsx scripts/remigrate-data.ts",
    "migrate-processed": "tsx scripts/migrate-processed-catalog.ts",
    "remigrate-processed": "tsx scripts/remigrate-processed-catalog.ts",
    "verify-migration": "tsx scripts/verify-migration.ts",
    "debug-collections": "tsx scripts/debug-collections.ts",
    "test-collections": "tsx scripts/test-collections.ts",
    "download-images": "tsx scripts/download-images.ts",
    "mark-images-ready": "tsx scripts/mark-images-ready.ts",
    "check-failed-images": "tsx scripts/check-failed-images.ts",
    "cleanup-orphaned-images": "tsx scripts/cleanup-orphaned-images.ts",
    "image-stats": "tsx scripts/image-stats.ts",
    "analyze-car-detections": "tsx scripts/analyze-car-detections.ts",
    "migrate-car-detection-analysis": "tsx scripts/migrate-car-detection-analysis.ts",
    "import-car-detection-analysis": "tsx scripts/import-car-detection-analysis.ts",
    "list-images-without-cars": "tsx scripts/list-images-without-cars.ts",
    "copy-images-without-cars": "tsx scripts/copy-images-without-cars.ts",
    "copy-images-by-coverage": "tsx scripts/copy-images-by-car-coverage.ts",
    "upload-images-to-supabase": "tsx scripts/upload-images-to-supabase.ts",
    "check-upload-status": "tsx scripts/check-upload-status.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@supabase/supabase-js": "^2.58.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.4",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  },
  "packageManager": "npm@10.9.2"
