{
  "buildCommand": "SKIP_ENV_VALIDATION=true npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "cd .. && npm install",
  "devCommand": "npm run dev",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ../package.json ../package-lock.json",
  "env": {
    "NODE_ENV": "production",
    "SKIP_ENV_VALIDATION": "true"
  }
}
